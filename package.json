{
  "name": "soulcache",
  "version": "1.0.0",
  "private": true,
  "description": "SoulCache - Universal Data Fetching & Caching Runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kasihagustinusT/soulcache.git"
  },
  "homepage": "https://soulcache.vercel.app",
  "bugs": {
    "url": "https://github.com/kasihagustinusT/soulcache/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "validate:exports": "node scripts/validate-exports.mjs",
    "validate:monorepo": "node scripts/validate-monorepo.mjs",
    "validate:docs": "node docs/scripts/validate.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@changesets/changelog-github": "^0.7.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.6",
    "typescript": "^5.8.0",
    "vitest": "^3.0.4"
  },
  "pnpm": {
    "overrides": {
      "fumadocs-core": "14.7.7",
      "fumadocs-ui": "14.7.7",
      "fumadocs-mdx": "11.5.8",
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "@types/react": "18.3.31",
      "@types/react-dom": "18.3.7"
    }
  }
}
