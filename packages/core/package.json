{
  "name": "@soulcache/core",
  "version": "1.0.0",
  "description": "SoulCache Core Runtime - Deterministic data fetching and caching runtime",
  "license": "MIT",
  "author": "Kasih Agustinus <kasihagustinus@users.noreply.github.com>",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "soulcache",
    "data-fetching",
    "caching",
    "query",
    "state-management",
    "typescript",
    "react",
    "runtime"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kasihagustinusT/soulcache.git",
    "directory": "packages/core"
  },
  "homepage": "https://soulcache.vercel.app",
  "bugs": {
    "url": "https://github.com/kasihagustinusT/soulcache/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/kasihagustinusT"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "tsup": "^8.0.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
